<style>
:root { --bg:#f4f7fb; --card:#fff; --ink:#1f2937; --muted:#6b7280; --line:#e5e7eb; --paid:#166534; --paid-bg:#dcfce7; --complete:#0f766e; --complete-bg:#ccfbf1; --danger:#991b1b; --danger-bg:#fee2e2; --manual:#7c3aed; --manual-bg:#ede9fe; }
* { box-sizing:border-box; }
body { margin:0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif; color:var(--ink); background:linear-gradient(180deg,#eef7f6 0%,var(--bg) 40%); }
.wrap { max-width:1680px; margin:0 auto; padding:24px; }
.hero,.panel { background:var(--card); border:1px solid var(--line); border-radius:16px; box-shadow:0 8px 24px rgba(16,24,40,.06); }
.hero { padding:20px; margin-bottom:16px; }
h1 { margin:0 0 6px; font-size:30px; }
.sub { margin:0; color:var(--muted); }
.cards { display:grid; grid-template-columns:repeat(4,minmax(180px,1fr)); gap:12px; margin:16px 0 0; }
.card { background:var(--card); border:1px solid var(--line); border-radius:14px; padding:14px; }
.k { margin:0; font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:.06em; }
.v { margin:6px 0 0; font-size:21px; font-weight:700; }
.v.small { font-size:18px; }
.panel { overflow:hidden; margin-bottom:16px; }
.toolbar { display:flex; gap:10px; align-items:center; justify-content:space-between; padding:14px; border-bottom:1px solid var(--line); flex-wrap:wrap; }
.panel h2 { margin:0; font-size:18px; }
.toolbar-actions { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
.toolbar input { padding:10px 12px; border-radius:10px; border:1px solid #cbd5e1; min-width:280px; }
.toggle-btn { padding:10px 12px; border-radius:10px; border:1px solid #0f766e; background:#0f766e; cursor:pointer; color:#fff; font-weight:700; white-space:nowrap; box-shadow:0 2px 10px rgba(15,118,110,.18); }
.toggle-btn:hover { background:#0b5f59; border-color:#0b5f59; }
.toggle-btn:focus-visible { outline:2px solid #99f6e4; outline-offset:2px; }
.meta { color:var(--muted); font-size:12px; }
.table-wrap { overflow:auto; max-height:66vh; }
table { width:100%; border-collapse:collapse; }
.greenn-table { min-width:1900px; }
.hot-table { min-width:1550px; }
th,td { padding:10px 12px; border-bottom:1px solid var(--line); vertical-align:top; }
th { position:sticky; top:0; background:#f8fafc; text-align:left; font-size:12px; text-transform:uppercase; letter-spacing:.04em; color:#334155; z-index:1; }
td.num { text-align:right; white-space:nowrap; font-variant-numeric:tabular-nums; }
.status { padding:4px 8px; border-radius:999px; font-size:12px; font-weight:600; display:inline-block; white-space:nowrap; }
.st-paid { color:var(--paid); background:var(--paid-bg); }
.st-complete { color:var(--complete); background:var(--complete-bg); }
.st-info { color:#1d4ed8; background:#dbeafe; }
.tag { display:inline-block; margin-left:6px; padding:2px 7px; border-radius:999px; font-size:11px; font-weight:600; vertical-align:middle; }
.tag-manual { color:var(--manual); background:var(--manual-bg); }
.tag-as { color:#854d0e; background:#fef08a; }
.tag-ds { color:#1d4ed8; background:#dbeafe; }
.legend-mini { margin-top:6px; font-size:11px; color:var(--muted); }
.legend-box { display:flex; flex-wrap:wrap; gap:6px; margin-top:8px; }
.legend-item { display:inline-flex; align-items:center; gap:6px; font-size:11px; color:var(--muted); }
.legend-dot { width:10px; height:10px; border-radius:999px; display:inline-block; border:1px solid #d1d5db; }
.dot-alert { background:#fee2e2; border-color:#fecaca; }
.dot-manual { background:#ede9fe; border-color:#ddd6fe; }
tr.row-alert td { background:#fff5f5; }
tr.row-alert td.cop { color:var(--danger); font-weight:700; }
.row-balance td { font-weight:700; background:#fafafa; }
.row-section td { font-weight:700; background:#f5f5f5; }
.val-pos { color:#047857; font-weight:700; }
.note { padding:10px 14px; color:var(--muted); font-size:12px; border-top:1px solid var(--line); background:#fafafa; }
.greenn-table td a { color:#1d4ed8; text-decoration:none; }
.greenn-table td a:hover { text-decoration:underline; }
@media (max-width:1100px) { .cards { grid-template-columns:repeat(2,minmax(180px,1fr)); } }
</style>
</head>
